# =============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# =============================================================

# --- Database (PostgreSQL) ---
# For local dev: postgresql://user:password@localhost:5432/dbname
# For production: use your cloud provider's connection string (e.g. Supabase, Neon, Railway)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# --- NextAuth ---
# Generate a strong secret: `openssl rand -base64 32`
NEXTAUTH_SECRET="your_strong_random_secret"
# Your live domain for production
NEXTAUTH_URL="https://your-domain.com"

# --- M-Pesa Daraja API ---
# Get from: https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY="your_consumer_key"
MPESA_CONSUMER_SECRET="your_consumer_secret"
MPESA_SHORTCODE="your_paybill_or_till_number"
MPESA_CALLBACK_URL="https://your-domain.com/api/mpesa/callback"
# 'sandbox' or 'production'
MPESA_ENVIRONMENT="sandbox"

# --- Africa's Talking (SMS) ---
# Get from: https://africastalking.com
AFRICAS_TALKING_USERNAME="sandbox"
AFRICAS_TALKING_APIKEY="your_api_key"
