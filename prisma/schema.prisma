generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  slogan    String?
  address   String?
  phone     String?
  createdAt DateTime @default(now())

  // Relations
  users                User[]
  roles                Role[]
  branches             Branch[]
  borrowers            Borrower[]
  loans                Loan[]
  loanProducts         LoanProduct[]
  installments         Installment[]
  repayments           Repayment[]
  registrationPayments RegistrationPayment[]
  interactions         Interaction[]
  targets              Target[]
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  fullName       String
  email          String       @unique
  roleId         String
  role           Role         @relation(fields: [roleId], references: [id])
  status         String       @default("active") // 'active' | 'suspended'
  createdAt      DateTime     @default(now())
  avatarUrl      String?
  marketingOptIn Boolean      @default(false)
  password       String?
  branchIds      String[] // Postgres supports arrays of strings

  // Optional: Implicit many-to-many with Branch
  // branches       Branch[]

  // Real world usage involves acting as loanOfficer/recordedBy
  approvedLoans Loan[]        @relation("ApprovedLoans")
  managedLoans  Loan[]        @relation("ManagedLoans")
  installments  Installment[]
  repayments    Repayment[]
  interactions  Interaction[]
}

model Role {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  name           String
  systemRole     Boolean       @default(false)
  permissions    String[]

  users User[]
}

model Branch {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  location       String
  isMain         Boolean      @default(false)

  borrowers    Borrower[]
  loans        Loan[]
  installments Installment[]
  interactions Interaction[]
  targets      Target[]
}

model Borrower {
  id                 String       @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id])
  fullName           String
  dateOfBirth        String?
  gender             String? // 'Male' | 'Female' | 'Other'
  nationalId         String
  phone              String       @unique
  email              String?
  address            String?
  employmentStatus   String? // 'Employed' | 'Self-employed' | 'Unemployed'
  monthlyIncome      Float?
  photoUrl           String?
  businessPhotoUrl   String?
  homeAssetsPhotoUrl String?
  branchId           String
  branch             Branch       @relation(fields: [branchId], references: [id])
  userId             String

  registrationFeeRequired Boolean   @default(false)
  registrationFeeAmount   Float?
  registrationFeePaid     Boolean   @default(false)
  registrationFeePaidAt   DateTime?
  registrationPaymentId   String?

  loans        Loan[]
  installments Installment[]
  repayments   Repayment[]
  interactions Interaction[]
}

model LoanProduct {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  category       String
  minAmount      Float
  maxAmount      Float
  interestRate   Float
  duration       Int
  repaymentCycle String // 'Weekly' | 'Monthly'
  processingFee  Float?

  loans Loan[]
}

model Loan {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])
  borrowerId        String
  borrower          Borrower     @relation(fields: [borrowerId], references: [id])
  loanProductId     String
  loanProduct       LoanProduct  @relation(fields: [loanProductId], references: [id])
  principal         Float
  interestRate      Float
  totalPayable      Float
  installmentAmount Float
  duration          Int
  issueDate         String
  status            String // 'Draft' | 'Pending Approval' | 'Approved' | 'Active' | 'Completed' | 'Rejected'

  loanOfficerId String
  loanOfficer   User   @relation("ManagedLoans", fields: [loanOfficerId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  lastPaymentDate String?

  approvedById String?
  approver     User?   @relation("ApprovedLoans", fields: [approvedById], references: [id])

  installments Installment[]
  repayments   Repayment[]
}

model Installment {
  id             String       @id @default(cuid())
  loanId         String
  loan           Loan         @relation(fields: [loanId], references: [id])
  borrowerId     String
  borrower       Borrower     @relation(fields: [borrowerId], references: [id])
  loanOfficerId  String
  loanOfficer    User         @relation(fields: [loanOfficerId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id])

  installmentNumber Int
  dueDate           String
  expectedAmount    Float
  paidAmount        Float  @default(0)
  status            String @default("Unpaid") // 'Paid' | 'Unpaid' | 'Partial' | 'Overdue'
}

model Repayment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  loanId         String
  loan           Loan         @relation(fields: [loanId], references: [id])
  borrowerId     String
  borrower       Borrower     @relation(fields: [borrowerId], references: [id])
  loanOfficerId  String
  loanOfficer    User         @relation(fields: [loanOfficerId], references: [id])

  transId             String
  amount              Float
  paymentDate         String
  collectedById       String
  method              String // 'Cash' | 'Bank Transfer' | 'Mobile Money'
  phone               String?
  balanceAfterPayment Float?
}

model RegistrationPayment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  borrowerId     String
  amount         Float
  currency       String       @default("KES")
  paymentMethod  String // 'Cash' | 'Bank Transfer' | 'Mobile Money'
  reference      String
  collectedBy    String
  createdAt      DateTime     @default(now())
  status         String?      @default("confirmed")
}

model Interaction {
  id             String       @id @default(cuid())
  borrowerId     String
  borrower       Borrower     @relation(fields: [borrowerId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id])
  recordedById   String
  recordedBy     User         @relation(fields: [recordedById], references: [id])
  recordedByName String
  timestamp      String
  notes          String       @db.Text
}

model Target {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  branchId       String
  branch         Branch       @relation(fields: [branchId], references: [id])
  userId         String?
  name           String
  type           String // 'disbursal_amount' | 'new_borrowers' | 'collection_rate' | 'portfolio_value'
  value          Float
  startDate      String
  endDate        String
}

model MpesaCallback {
  id                String   @id @default(cuid())
  transactionType   String?
  transId           String?
  transTime         String?
  transAmount       String?
  businessShortCode String?
  billRefNumber     String?
  msisdn            String?
  firstName         String?
  middleName        String?
  lastName          String?
  status            String   @default("Processed") // 'Processed' | 'Failed'
  errorMessage      String?  @db.Text
  createdAt         DateTime @default(now())
}

